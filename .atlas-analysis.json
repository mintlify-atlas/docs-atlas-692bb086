  "keyFeatures": [
    "Encrypted secret vault (AES-256-GCM) - credentials never exposed to agents",
    "Agent-Key authentication with service-level scoping",
    "LLM-based risk assessment for automatic request evaluation",
    "Human-in-the-loop approval queue for high-risk actions",
    "Transparent API proxying with credential injection",
    "Intent integrity checking to detect payload mismatches",
    "Global kill switch for instant agent session blocking",
    "Idempotency support with automatic request deduplication",
    "TTL-based cleanup for approved-but-unexecuted requests"
  ],
  "publicApiSurface": [
    "POST /proxy - Submit agent request for proxying",
    "GET /status/:actionId - Poll approval status",
    "POST /proxy/execute/:actionId - Execute approved request",
    "POST /auth/register - Register new user",
    "POST /auth/login - Authenticate user",
    "POST /auth/refresh - Refresh access token",
    "GET /auth/me - Get current user",
    "GET /services - List registered services",
    "POST /services - Register new service",
    "PUT /services/:id - Update service",
    "DELETE /services/:id - Delete service",
    "POST /services/:id/credentials - Store/update service credentials",
    "GET /agents - List agents",
    "POST /agents - Create agent",
    "PUT /agents/:id - Update agent",
    "DELETE /agents/:id - Delete agent",
    "PUT /agents/:id/services - Update agent service scope",
    "GET /approvals/pending - List pending approvals",
    "PATCH /approvals/:actionId/approve - Approve action",
    "PATCH /approvals/:actionId/deny - Deny action"
  ]
}
